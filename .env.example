# ── LLM ──────────────────────────────────────────────────────────────────────
# For Gemini: https://aistudio.google.com/
# For OpenAI: https://platform.openai.com/
LLM_API_KEY=your_api_key_here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sender address must be on a verified Resend domain
EMAIL_SENDER=news@yourdomain.com
RESEND_API_KEY=re_your_resend_api_key_here

# ── Website ───────────────────────────────────────────────────────────────────
# Base URL used for "Read Full Article" links in the email digest.
# IMPORTANT: match the port that Next.js is actually running on (3000 or 3001).
# Local dev:   http://localhost:3000  (or 3001 if 3000 was taken)
# Production:  https://yoursite.com  (or your Render domain)
WEBSITE_BASE_URL=http://localhost:3000

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Leave blank to use SQLite locally (no account needed for local dev).
# Set both to switch to Supabase PostgreSQL in production.
SUPABASE_URL=
SUPABASE_KEY=

# ── File Storage (Supabase) ───────────────────────────────────────────────────
# Leave blank to use local inbox/ folder.
# Set to your Supabase Storage bucket name for production.
SUPABASE_STORAGE_BUCKET=

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Password for the /admin route on the Next.js website.
# IMPORTANT: Use a strong randomly generated password in production (20+ chars).
# Generate one with: openssl rand -base64 20
# The app will log a security warning on login if the password is < 16 characters.
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_RANDOM_PASSWORD

# ── Environment ───────────────────────────────────────────────────────────────
# development  → SQLite + local folders + verbose logging
# production   → Supabase DB + Supabase Storage
ENV=development

# ── Optional overrides (defaults are in config/config.yaml) ──────────────────
# LLM_MODEL=gemini-2.5-flash
# STORAGE_PROVIDER=local
# INBOX_PATH=./inbox
