# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: leave blank — reads from ../data/articles.db via better-sqlite3
# Production (Render): set both Supabase vars below
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, never exposed to browser

# Path to SQLite DB (local dev only — defaults to ../data/articles.db)
# SQLITE_DB_PATH=/absolute/path/to/articles.db

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme
# Secret used to sign the admin session cookie (any random string, min 32 chars)
AUTH_SECRET=replace-with-a-long-random-string

# ── Pipeline trigger (local dev) ─────────────────────────────────────────────
# Absolute path to the Python pipeline's inbox folder.
# Uploaded PDFs are saved here so the watchdog picks them up automatically.
INBOX_PATH=../inbox
